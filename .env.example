# Credenciais padrao para login local de desenvolvimento
EXPO_PUBLIC_DEFAULT_AUTH_EMAIL=admin@gmail.com
EXPO_PUBLIC_DEFAULT_AUTH_PASSWORD=12345678

# URL local do app para testes no ambiente de desenvolvimento
EXPO_PUBLIC_APP_URL_LOCAL=http://localhost:8081

# URL publica com DNS para acesso externo ao app
EXPO_PUBLIC_APP_URL_DNS=https://app.gsfinanceira.com.br

# URL local de callback/redirecionamento do Google Auth
EXPO_PUBLIC_GOOGLE_REDIRECT_URL_LOCAL=http://localhost:8081/auth/google/callback

# URL publica com DNS de callback/redirecionamento do Google Auth
EXPO_PUBLIC_GOOGLE_REDIRECT_URL_DNS=https://app.gsfinanceira.com.br/auth/google/callback

# Client ID publico do Google OAuth usado no app
EXPO_PUBLIC_GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID_AQUI

# Client ID privado do Google OAuth usado no backend/API
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID_AQUI

# Secret key privada do Google OAuth usada no backend/API
GOOGLE_SECRET_KEY=SEU_GOOGLE_SECRET_KEY_AQUI
